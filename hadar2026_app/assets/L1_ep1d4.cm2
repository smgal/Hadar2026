	Map::SetRow("▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤▤")

	## 물의 정령과 합류하지 않았다면 불을 꺼도 스스로 빛을 내는 구역이 있음 
	if (Not(Flag::IsSet(GFD4_JOINNED_SOUL_OF_WATER)))
		Map::SetLightArea(12,16, 12,16)

	## 제일 위의 벽
	if (Flag::IsSet(GFD4_LEVER1_RIGHT))
		temp_x.assign(11)
		temp_y.assign(11)
		Map::ChangeTile(Add(temp_x,0), temp_y, TILE_GROUND)
		Map::ChangeTile(Add(temp_x,1), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,2), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,3), temp_y, TILE_PASS)
		Map::ChangeTile(Add(temp_x,4), temp_y, TILE_BLOCK)

	## 위에서 2번 째 벽
	if (Flag::IsSet(GFD4_LEVER2_RIGHT))
		temp_x.assign(11)
		temp_y.assign(12)
		Map::ChangeTile(Add(temp_x,0), temp_y, TILE_GROUND)
		Map::ChangeTile(Add(temp_x,1), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,2), temp_y, TILE_PASS)
		Map::ChangeTile(Add(temp_x,3), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,4), temp_y, TILE_BLOCK)

	## 위에서 3번 째 벽
	if (Flag::IsSet(GFD4_LEVER3_LEFT))
		temp_x.assign(11)
		temp_y.assign(13)
		Map::ChangeTile(Add(temp_x,0), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,1), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,2), temp_y, TILE_PASS)
		Map::ChangeTile(Add(temp_x,3), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,4), temp_y, TILE_GROUND)

	## 위에서 4번 째 벽
	if (Flag::IsSet(GFD4_LEVER4_LEFT))
		temp_x.assign(11)
		temp_y.assign(14)
		Map::ChangeTile(Add(temp_x,0), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,1), temp_y, TILE_PASS)
		Map::ChangeTile(Add(temp_x,2), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,3), temp_y, TILE_BLOCK)
		Map::ChangeTile(Add(temp_x,4), temp_y, TILE_GROUND)

	## 트릭 '아래' 방향
	if (Flag::IsSet(GFD4_BLOCK_MOVED_DOWN))
		temp_x.assign(24)
		temp_y.assign(10)
		Map::ChangeTile(temp_x, Add(temp_y,1), TILE_GROUND)
		Map::ChangeTile(temp_x, Add(temp_y,3), TILE_BLOCK)

	## 트릭 '아래' 방향
	if (Flag::IsSet(GFD4_BLOCK_MOVED_RIGHT))
		temp_x.assign(24)
		temp_y.assign(10)
		Map::ChangeTile(Add(temp_x,-2), Add(temp_y,1), TILE_GROUND)
		Map::ChangeTile(temp_x, Add(temp_y,1), TILE_BLOCK)
