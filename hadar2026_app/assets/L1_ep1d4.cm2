############################

variable(temp)        
variable(temp_x)
variable(temp_y)
variable(flag_event_hit)

# 상수 설정
variable(TILE_GROUND)
variable(TILE_PASS)
variable(TILE_BLOCK)
TILE_GROUND.assign(43)
TILE_PASS.assign(42)
TILE_BLOCK.assign(40)


if (Equal(ScriptMode(), FLAG_EVENT))
	if (On(17,20))
		if (Not(Flag::IsSet(GFD4_FELT_STRANGE)))
			DisplayMap()
			Talk("@7그다지 육감이 좋은 편은 아니지만 이곳은 뭔가 다르다는 느낌을 받을 수는 있었다.");
			PressAnyKey();
			Flag::Set(GFD4_FELT_STRANGE)

			Select::Init()
			Select::Add("어떤 행동을 하시겠습니까?")
			Select::Add("소리를 지른다")
			Select::Add("한 곳을 응시한다")
			Select::Run()
			temp.assign(Select::Result())
			if (Equal(temp, 0))
				Talk("@7당신은 그냥 무시하기로 했다.");
			if (Equal(temp, 1))
				Talk("@7당신이 지른 소리는 동굴 벽을 울리며 메아리 친다.");
			if (Equal(temp, 2))
				Talk("@7열심히 노려 보았지만 눈만 아파올 뿐이다.");

	if (On(13,17))
		## 물의 정령과 합류하지 않았으면서 불을 켠 상태 
		if (Not(Flag::IsSet(GFD4_JOINNED_SOUL_OF_WATER)))
			if (Party::CheckIf(CHECKIF_MAGICTORCH))
				Talk("@7이 앞에 뭔가 있는 듯 보이지만 주위가 밝아 도리어 확인하기가 어렵다");

	if (On(12,16))
		## 물의 정령과 합류하지 않았으면서 불을 끈 상태 
		if (Not(Flag::IsSet(GFD4_JOINNED_SOUL_OF_WATER)))
			if (Not(Party::CheckIf(CHECKIF_MAGICTORCH)))
				DisplayMap()
				Talk("@7불이 꺼진 상태이지만 희미하게 스스로 빛을 내는 물체가 있다. 물 속에 사는 정령이 아닌가 생각된다.");
				PressAnyKey();

				Select::Init()
				Select::Add("당신 앞에는 물의 정령이 있습니다.")
				Select::Add("물의 정령에게 호의를 보낸다")
				Select::Add("무시한다")
				Select::Run()
				temp.assign(Select::Result())
				if (Equal(temp, 1))
					Talk("@7당신은 물의 정령에 대해 경계심을 완전히 버렸다. 당신의 호의를 알아챈 물의 정령은 당신의 곁을 따라 다니게 되었다.");
					Player::AssignFromEnemyData(2,7)
					Player::ChangeAttribute(2, "name", "물의 정령")
					Player::ChangeAttribute(2, "class", 9)
					Player::ChangeAttribute(2, "level(magic)", 4)
					Player::ChangeAttribute(2, "accuracy(magic)", 15)
					DisplayStatus()
					Flag::Set(GFD4_JOINNED_SOUL_OF_WATER)

					## 빛나는 부분을 제거
					Map::ResetLightArea(12,16, 12,16)
					DisplayMap()

	## 벽 밀기 트릭
	if (OnArea(16,11,16,14))

		## 제일 위의 벽
		if (On(16,11))
			DisplayMap()
			Select::Init()
			Select::Add("바닥에는 레버가 놓여 있습니다.")
			Select::Add("왼쪽으로 민다")
			Select::Add("오른쪽으로 민다")
			Select::Run()
			temp.assign(Select::Result())
			if (Equal(temp, 1))
				if (Flag::IsSet(GFD4_LEVER1_RIGHT))
					Talk("@7굉음이 울리며 앞 쪽의 벽이 움직인다")

					## 벽의 왼쪽 이동
					temp_x.assign(Add(Party::PosX(),-5))
					temp_y.assign(Party::PosY())
					Map::ChangeTile(Add(temp_x,0), temp_y, TILE_BLOCK)
					Map::ChangeTile(Add(temp_x,1), temp_y, TILE_BLOCK)
					Map::ChangeTile(Add(temp_x,2), temp_y, TILE_PASS)
					Map::ChangeTile(Add(temp_x,3), temp_y, TILE_BLOCK)
					Map::ChangeTile(Add(temp_x,4), temp_y, TILE_GROUND)
					DisplayMap()

					Flag::Reset(GFD4_LEVER1_RIGHT)
				else
					Talk("@7아무런 변화도 일어나지 않았다")
			if (Equal(temp, 2))
				if (Not(Flag::IsSet(GFD4_LEVER1_RIGHT)))
