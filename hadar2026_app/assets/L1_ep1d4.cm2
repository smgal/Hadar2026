	## 트릭 '아래' 방향
	if (On(24,10))
		if (Not(Flag::IsSet(GFD4_BLOCK_MOVED_DOWN)))
			DisplayMap()
			Select::Init()
			Select::Add("아래 쪽은 벽에는 레일이 깔려 있어서 밀 수 있을 것 같다.")
			Select::Add("아래 쪽으로 민다")
			Select::Add("그냥 둔다")
			Select::Run()
			temp.assign(Select::Result())
			if (Equal(temp, 1))
				## 벽을 아래로 이동
				temp_x.assign(Party::PosX())
				temp_y.assign(Party::PosY())
				Map::ChangeTile(temp_x, Add(temp_y,1), TILE_GROUND)
				Map::ChangeTile(temp_x, Add(temp_y,3), TILE_BLOCK)
				DisplayMap()

				Flag::Set(GFD4_BLOCK_MOVED_DOWN)

	## 트릭 '-> 방향'
