	## 최초로 실행을 할 때 주인공의 status를 보정한다
	## 최초는 디폴트 값이다.
	if (Not(Flag::IsSet(GFD0_IS_FIRST)))
		Player::ChangeAttribute(1, "name", "슴갈")
		Player::ChangeAttribute(1, "class", 8)
		Player::ChangeAttribute(1, "level", 3)
		Player::ApplyAttribute(1)
		Flag::Set(GFD0_IS_FIRST)

	## 여관에서 방을 빌렸을 경우
	if (Flag::IsSet(GFD0_RENT_ROOM))
		Map::ChangeTile(18,36,30)
