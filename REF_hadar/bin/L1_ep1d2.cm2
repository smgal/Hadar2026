if (Equal(ScriptMode(), FLAG_TALK))
	# 矫眉
	if (On(39,14))
		Talk("@7寸脚 菊俊绰 缴窍霸 何菩等 矫眉啊 乐菌促, 弊府绊 弊 糠俊绰 弊啊 购啊甫 舅府绊磊 窍绰 淀茄 狼固狼 皋矫瘤啊 巢败廉 乐菌促.")
		PressAnyKey()
		Talk("@7霉 锅掳 厘")
		Talk("")
		Talk("唱绰 快龋利栏肺 弊甸俊霸 立辟窍妨 沁瘤父 弊甸篮 唱甫 弊犯霸 毫林瘤 臼绰促. 富捞 烹窍瘤 臼栏聪 弊甸俊霸 唱狼 龋狼甫 傈窍绰 巴篮 阂啊瓷 窍促.")
		PressAnyKey()
		Talk("@7滴 锅掳 厘")
		Talk("")
		Talk("捞 规菩甫 啊瘤绊 乐绰 唱甫 畴赴 巴捞 盒疙窍瘤父 弊 捞蜡甫 舅 荐啊 绝促. 捞 规菩俊 弊妨柳 寇传捞 弊甸阑 蕊盒矫虐绰 巴老鳖?")
		PressAnyKey()
		Talk("@7技 锅掳 厘")
		Talk("")
		Talk("老窜, 唱绰 何惑 锭巩俊 弊甸苞 歹 捞惑 轿快扁啊 塞甸促. 霸促啊 咯扁甫 哈绢唱搁 困氰窍扁俊 酒贰肺 郴妨 哎 荐档 绝促. 盒疙 贸澜 规菩啊 乐带 镑捞 捞 摸老刨单 弊率栏肺 唱啊绰 规过阑 档公瘤 舅 荐啊 绝促.")
		PressAnyKey()
		if (Not(Flag::IsSet(GFD2_TAKE_GOLDED_SHIELD)))
			Select::Init()
			Select::Add("缴窍霸 何菩等 矫眉 糠俊绰 炔陛狼 规菩啊 初咯 乐促.")
			Select::Add("规菩甫 啊柳促")
			Select::Add("弊成 敌促")
			Select::Run()
			temp.assign(Select::Result())
			if (Equal(temp, 1))
				Talk("@7炔陛 蝴栏肺 蝴唱绰 规菩俊绰 目促鄂 传 窍唱啊 炼阿登绢 乐菌促. 例措 乞裹窍霸绰 焊捞瘤 臼绰 规菩捞促.")
				Talk("")
				Talk("@B[炔陛 规菩 +1]")
				PressAnyKey()
				## 炔陛 规菩甫 厘馒
				Player::ChangeAttribute(1, "shield", 5)
				Player::ChangeAttribute(1, "pow_of_shield", 5)
				Flag::Set(GFD2_TAKE_GOLDED_SHIELD)

				Talk("@7规菩甫 笼绢 甸磊 弊 关俊绰 绢凋啊俊辑 荤侩茄 淀茄 凯艰啊 汝矾 乐菌促.")
				Talk("")
				Talk("@B[狼巩狼 凯艰 +1]")
				Flag::Set(GFD2_TAKE_USED_KEY)

